<Window x:Class="MileStone6Presenter.AddEvent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MileStone6Presenter"
        mc:Ignorable="d"
        Title="AddEvent" Height="450" Width="750" MinHeight="500" MinWidth="750">
    <Grid x:Name="EventGrid" Background="LightSteelBlue" IsHitTestVisible="True">
        <Button Click="CancelButton_CLicked" Content="Return/Cancel" Background="NavajoWhite" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="10px" FontSize="20" BorderBrush="Crimson" BorderThickness="5"></Button>
        <Button Background="DarkOrange" Content="X" Width="55" Height="55" VerticalAlignment="Top" HorizontalAlignment="Right" FontSize="20"  Click="ToLeaveButton_Clicked" BorderBrush="Black" BorderThickness="5"></Button>

        <StackPanel>
            <Border BorderBrush="Black" BorderThickness="5" HorizontalAlignment="Center" CornerRadius="2.5">
                <TextBlock Text="Fill out and submit!" Padding="10px" FontSize="20" HorizontalAlignment="Center" Background="White" ></TextBlock>
            </Border>
            <GroupBox Background="IndianRed" MinWidth="150" Margin="10" Width="500">
                <StackPanel>
                    <TextBlock Margin="10" FontSize="25">Add A Category</TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="25" Margin="15">Details:</TextBlock>
                        <TextBox x:Name="eventDetails" Grid.Column="1" Margin="5" FontSize="15" TextAlignment="Center" VerticalContentAlignment="Center" BorderBrush="Transparent" BorderThickness="5"></TextBox>

                        <TextBlock FontSize="25" Margin="15" Grid.Row="1">Category:</TextBlock>
                        <ComboBox x:Name="eventCategory" Grid.Column="1" Grid.Row="1" Margin="10" FontSize="15"  VerticalContentAlignment="Center"></ComboBox>

                        <TextBlock FontSize="25" Margin="15" Grid.Row="2">Date:</TextBlock>
                        <DatePicker x:Name="eventDate" Grid.Row="2" Grid.Column="1" Margin="5" FontSize="15"  VerticalContentAlignment="Center" BorderBrush="Transparent" BorderThickness="5"></DatePicker>

                        <TextBlock FontSize="25" Margin="15" Grid.Row="3">Duration:</TextBlock>
                        <TextBox x:Name="eventDuration" Grid.Row="3" Grid.Column="1" Margin="5" FontSize="15" TextAlignment="Center" VerticalContentAlignment="Center" BorderBrush="Transparent" BorderThickness="5"></TextBox>

                        <TextBox x:Name="ErrorBox" IsHitTestVisible="False" Background="White" Grid.Row="4"  FontSize="10" TextWrapping="Wrap" Margin="10" Width="200" Padding="2"></TextBox>
                        <Button x:Name="Submit" Background="LightBlue" Grid.Row="4" Grid.Column="2" FontSize="20" Margin="10" Width="200" Padding="10" Click="Submit_Click">Add</Button>
                    </Grid>
                </StackPanel>
            </GroupBox>
            <Button Background="LightGreen" Content="New" Width="100" Height="43" Margin="600 -265 0 0" VerticalAlignment="Top" FontSize="20"  Click="ConveniantAddCatButton_Click"  BorderBrush="Black" BorderThickness="5"></Button>

        </StackPanel>
    </Grid>
</Window>
