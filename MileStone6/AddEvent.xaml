<Window x:Class="MileStone6.AddEvent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MileStone6"
        mc:Ignorable="d"
        Title="AddEvent" Height="450" Width="800" MinHeight="500" MinWidth="600">
    <Grid Background="LightSteelBlue">
        <Button Click="CancelButton_CLicked" Content="Return/Cancel" Background="NavajoWhite" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="10px" FontSize="20" BorderBrush="Crimson" BorderThickness="5"></Button>
        <StackPanel>
            <Border BorderBrush="Black" BorderThickness="5" HorizontalAlignment="Center" CornerRadius="2.5">
                <TextBlock Text="Fill out and submit!" Padding="10px" FontSize="20" HorizontalAlignment="Center" Background="White" ></TextBlock>
            </Border>
            <GroupBox Background="IndianRed" MinWidth="150" Margin="10" Width="500">
                <StackPanel>
                    <TextBlock Margin="10" FontSize="25">Add A Category</TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="25" Margin="15">Details:</TextBlock>
                        <TextBox x:Name="Details" Grid.Column="1" Margin="10" FontSize="15" TextAlignment="Center" VerticalContentAlignment="Center"></TextBox>

                        <TextBlock FontSize="25" Margin="15" Grid.Row="1">Category:</TextBlock>
                        <TextBox x:Name="eventcategory" Grid.Row="1" Grid.Column="1" Margin="10" FontSize="15" TextAlignment="Center" VerticalContentAlignment="Center"></TextBox>
                        
                        <TextBlock FontSize="25" Margin="15" Grid.Row="2">Date:</TextBlock>
                        <TextBox x:Name="eventdate" Grid.Row="2" Grid.Column="1" Margin="10" FontSize="15" TextAlignment="Center" VerticalContentAlignment="Center"></TextBox>
                        
                        <TextBlock FontSize="25" Margin="15" Grid.Row="3">Duration:</TextBlock>
                        <TextBox x:Name="eventDuration" Grid.Row="3" Grid.Column="1" Margin="10" FontSize="15" TextAlignment="Center" VerticalContentAlignment="Center"></TextBox>

                        <Button x:Name="Submit" Background="LightBlue" Grid.Row="4" Grid.ColumnSpan="2" FontSize="20" Margin="10" Width="200" Padding="10">Add</Button>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>
